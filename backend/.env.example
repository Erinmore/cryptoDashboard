# =============================================================
# CRYPTEX - Backend Environment Variables
# Copia este fichero a .env y rellena los valores reales
# NUNCA subas .env a git
# =============================================================

# Server
PORT=3000
NODE_ENV=development

# ─── APIs de IA ───────────────────────────────────────────────
# Anthropic (Claude API)
# Obtén tu key en: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── APIs de Datos de Mercado ─────────────────────────────────
# CoinGecko (OHLC + BTC Dominance)
# Free tier no requiere key para la mayoría de endpoints
# Si tienes plan de pago, añádela aquí para mayor rate limit
COINGECKO_API_KEY=

# CryptoPanic (sentimiento comunitario)
# Obtén tu token en: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── APIs de Sentimiento ──────────────────────────────────────
# alternative.me Fear & Greed Index
# NO requiere API key ni registro — API completamente pública
# https://alternative.me/crypto/fear-and-greed-index/
# (Dejar vacío — se usa sin autenticación)

# LunarCrush (Social Score, Galaxy Score, sentimiento social)
# Registro GRATUITO en: https://lunarcrush.com/
# Dashboard API: https://lunarcrush.com/settings/api
# Si no se configura, el social score se omite (degraded mode)
LUNARCRUSH_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── APIs de Derivados ────────────────────────────────────────
# Coinalyze (Funding Rate, Open Interest, Long/Short Ratio)
# Registro GRATUITO en: https://coinalyze.net/
# Dashboard API: https://app.coinalyze.net/api-keys
# Si no se configura, los datos de derivados se omiten (degraded mode)
COINALYZE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Base de Datos ────────────────────────────────────────────
DB_PATH=./data/cryptex.db

# ─── Cache TTL (segundos) ─────────────────────────────────────
CACHE_OHLC_TTL=60
CACHE_SENTIMENT_TTL=300
CACHE_FEAR_GREED_TTL=600
CACHE_FUNDING_RATE_TTL=1800
CACHE_OPEN_INTEREST_TTL=300
CACHE_LONG_SHORT_TTL=300
CACHE_LIQUIDATIONS_TTL=300
CACHE_BTC_DOMINANCE_TTL=600

# ─── Logging ──────────────────────────────────────────────────
LOG_LEVEL=info
